```gitignore
# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# -------------------------------------------------------
# Virtual Environments
# -------------------------------------------------------
.venv/
venv/
env/
ENV/

# -------------------------------------------------------
# Environment Variables
# -------------------------------------------------------
.env
.env.*
!.env.example

# -------------------------------------------------------
# IDE / Editor
# -------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# -------------------------------------------------------
# OS Files
# -------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------------------------------------
# Logs
# -------------------------------------------------------
logs/
*.log

# -------------------------------------------------------
# Build / Distribution
# -------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# -------------------------------------------------------
# Testing
# -------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# -------------------------------------------------------
# Type Checking
# -------------------------------------------------------
.mypy_cache/
.pyre/
.pytype/

# -------------------------------------------------------
# Linting
# -------------------------------------------------------
.ruff_cache/

# -------------------------------------------------------
# Jupyter
# -------------------------------------------------------
.ipynb_checkpoints/

# -------------------------------------------------------
# Python Version
# -------------------------------------------------------
.python-version

# -------------------------------------------------------
# uv
# -------------------------------------------------------
#uv.lock

# Uncomment if building a reusable library.
# For applications, many teams COMMIT uv.lock.
# !uv.lock

# -------------------------------------------------------
# Local Databases
# -------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -------------------------------------------------------
# Qdrant Local Storage
# -------------------------------------------------------
qdrant_storage/
storage/

# -------------------------------------------------------
# ChromaDB (if used)
# -------------------------------------------------------
chroma/

# -------------------------------------------------------
# Vector Stores
# -------------------------------------------------------
vector_store/
vectordb/

# -------------------------------------------------------
# Uploaded Files
# -------------------------------------------------------
uploads/
downloads/

# -------------------------------------------------------
# AI Models
# -------------------------------------------------------
models/
checkpoints/
weights/

*.pt
*.pth
*.onnx
*.h5
*.keras
*.gguf
*.bin
*.safetensors

# -------------------------------------------------------
# Temporary Files
# -------------------------------------------------------
tmp/
temp/
.cache/

# -------------------------------------------------------
# Documentation Builds
# -------------------------------------------------------
site/

# -------------------------------------------------------
# Secrets
# -------------------------------------------------------
secrets/
credentials.json
service-account.json

# -------------------------------------------------------
# Misc
# -------------------------------------------------------
*.swp
*.bak
*.tmp
```
